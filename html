function f(b, key) {
  return b.fields[key] || '—';
}

function fdt(b, key) {
  const v = b.fields[key];
  if (!v) return '—';
  try {
    return new Date(v).toLocaleString('en-US', {
      weekday: 'short', month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit', hour12: true
    });
  } catch { return v; }
}

